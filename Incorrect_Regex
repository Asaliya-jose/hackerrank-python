import re

def check_regex():
    import sys
    input_data = sys.stdin.read().splitlines()
    
    if not input_data:
        return
        
    t = int(input_data[0])
    for i in range(1, t + 1):
        s = input_data[i]
        try:
            re.compile(s)
            print("True")
        except re.error:
            print("False")

if __name__ == "__main__":
    check_regex()
