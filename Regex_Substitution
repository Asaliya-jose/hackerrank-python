import re

S = input()
k = input()

# (?=(pattern)) allows for overlapping matches
pattern = re.compile(f'(?=({re.escape(k)}))')
matches = list(pattern.finditer(S))

if not matches:
    print((-1, -1))
else:
    for m in matches:
        start = m.start()
        # The length is calculated based on the searched string 'k'
        end = start + len(k) - 1
        print((start, end))
